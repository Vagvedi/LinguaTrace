{
  "name": "linguatrace",
  "version": "1.2.0",
  "description": "AI-powered writing style analysis and authorship comparison tool",
  "main": "app.py",
  "scripts": {
    "build-css": "tailwindcss -i ./static/css/input.css -o ./static/css/style.css --watch",
    "build-css-prod": "tailwindcss -i ./static/css/input.css -o ./static/css/style.css --minify"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38"
  },
  "keywords": ["nlp", "authorship", "writing-style", "ai", "analysis"],
  "author": "LinguaTrace Team",
  "license": "MIT"
}
